# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/
app-expo/node_modules/
packages/electron/node_modules/

# Expo
.expo/
app-expo/.expo/
app-expo/web-build/
app-expo/expo-env.d.ts

# EAS
app-expo/eas.json

# Build outputs — ignora conteúdo mas preserva estrutura de pastas
dist/**
!dist/web/.gitkeep
!dist/electron/.gitkeep
!dist/android/.gitkeep

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
app-expo/ios/
app-expo/android/
